table Medidas
	lineageTag: 1e1d32a5-7c2f-4716-8c76-00352184dedd

	measure 'Tx Conversão Geral' =
			
			DIVIDE(
			    CALCULATE(COUNTROWS(dados_mkt), dados_mkt[Comprou] = 1),
			    COUNTROWS(dados_mkt)
			)
		formatString: 0%;-0%;0%
		lineageTag: 0fe613bc-e5df-4542-bee1-157673fdb5b7

	measure 'Tx Coversão Web' =
			DIVIDE(
			    SUM(dados_mkt[Numero de Compras na Web]),
			    SUM(dados_mkt[Numero Visitas WebSite Mes]))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 1e18ed83-27db-4f7b-b083-63dcceeefd8f

	measure 'Total Visitas' = SUM(dados_mkt[Numero Visitas WebSite Mes])
		formatString: 0
		lineageTag: 0f757a72-c7b6-41d0-aa68-2c79d0115fad

	measure 'Ticket Médio' = ```
			AVERAGE(dados_mkt[Total Gasto])
			
			```
		lineageTag: 5d40f3c7-b4f5-4ec9-a4bd-ad5720f85530

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Retenção Campanhas' =
			
			VAR ComprouUma = CALCULATE(COUNTROWS(dados_mkt), dados_mkt[Total Campanhas] >= 1)
			VAR ComprouDuas = CALCULATE(COUNTROWS(dados_mkt), dados_mkt[Total Campanhas] >= 2)
			RETURN DIVIDE(ComprouDuas, ComprouUma)
		lineageTag: f6b1a6fd-f0fb-42fa-bb3f-52beccc9ebd7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Média Compras Web' = AVERAGE(dados_mkt[Numero de Compras na Web])
		lineageTag: c741ed15-e5c5-4312-b39f-e4cff759d4ce

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Média Visitas' = AVERAGE(dados_mkt[Numero Visitas WebSite Mes])
		lineageTag: c77f6b55-b1ea-4731-b08b-16bb2e63e4b5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tx Participação' =
			
			DIVIDE(
			    [Total Gasto Medida],
			    CALCULATE(
			        [Total Gasto Medida],
			        ALL(dados_mkt[Pais])
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 0fd9e2de-7418-432f-9bde-868a8c9ca665

	measure 'Total Gasto Medida' =
			
			SUM(dados_mkt[Total Gasto])
		formatString: 0
		lineageTag: 1d1af576-ee17-40f6-8c60-6e58c49a2e39

	measure 'Total Clientes' = DISTINCTCOUNT(dados_mkt[ID])
		formatString: 0
		lineageTag: 1e434d2b-fc3b-42c6-b2eb-64c7cc7a3005

	measure 'Card Total Clientes' =
			
			VAR Clientes = FORMAT([Total Clientes], "#,##0")
			
			RETURN
			"
			<div style='
			width:100%;
			height:100%;
			border-radius:14px;
			padding:10px 14px;
			box-sizing:border-box;
			background:linear-gradient(135deg,
			#4B3FAF 0%,
			#5C4CE0 45%,
			#733EEE 100%);
			font-family:Segoe UI;
			position:relative;
			overflow:hidden;
			'>
			
			<div style='
			position:absolute;
			top:-30px;
			right:-20px;
			width:90px;
			height:90px;
			border-radius:50%;
			background:rgba(255,255,255,.08);
			'></div>
			
			<div style='
			display:flex;
			align-items:center;
			justify-content:space-between;
			height:100%;
			'>
			
			<div>
			
			<div style='
			font-size:13px;
			color:#E9E5FF;
			margin-bottom:4px;
			'>
			Total de Clientes
			</div>
			
			<div style='
			font-size:30px;
			font-weight:700;
			color:#FFD54F;
			line-height:30px;
			'>
			" & Clientes & "
			</div>
			
			</div>
			
			<div style='
			display:flex;
			align-items:center;
			justify-content:center;
			width:48px;
			height:48px;
			border-radius:50%;
			background-color:#02C39A;
			box-shadow: 0 4px 8px rgba(0,0,0,0.2);
			'>
			<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white' width='28px' height='28px'>
			  <path d='M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z'/>
			</svg>
			</div>
			
			</div>
			
			</div>
			"
		lineageTag: 3cec44db-75d1-42ff-bcf6-67a282c5505c

