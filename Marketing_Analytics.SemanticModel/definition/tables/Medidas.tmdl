	measure 'Botao HTML Cliente' =
			
			"
			<div style='
			width:100%;
			height:100%;
			padding:12px 10px;
			border-radius:18px;
			box-sizing:border-box;
			background:linear-gradient(135deg,#4B3FAF 0%,#5C4CE0 45%,#733EEE 100%);
			font-family:Segoe UI;
			position:relative;
			overflow:hidden;
			
			display:flex;
			flex-direction:column;
			align-items:center;
			justify-content:center;
			
			gap:6px;
			
			box-shadow:0 4px 10px rgba(0,0,0,.30);
			'>
			
			    <div style='
			    position:absolute;
			    top:-12px;
			    right:-12px;
			    width:60px;
			    height:60px;
			    border-radius:50%;
			    background:rgba(255,255,255,.05);
			    '></div>
			
			    <div style='
			    width:40px;
			    height:40px;
			    border-radius:50%;
			    background:#02C39A;
			
			    display:flex;
			    align-items:center;
			    justify-content:center;
			
			    box-shadow:0 2px 5px rgba(0,0,0,.25);
			    '>
			
			        <svg xmlns='http://www.w3.org/2000/svg'
			             viewBox='0 0 24 24'
			             fill='white'
